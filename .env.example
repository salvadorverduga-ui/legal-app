# .env.example
# Copiar como .env y completar con los valores reales del proyecto Supabase.
# Nunca commitear el archivo .env (ya está en .gitignore).
#
# En producción (Vercel) estas variables NO se leen desde un archivo .env:
# se configuran en Project Settings → Environment Variables del proyecto en
# Vercel. El frontend estático las obtiene en tiempo de ejecución a través de
# api/config.js (ver ese archivo y frontend/js/config.js).

# Dashboard de Supabase → Project Settings → API → Project URL
SUPABASE_URL=

# Dashboard de Supabase → Project Settings → API → Project API keys → anon / public
# Segura para exponer en el navegador: el acceso real lo controla RLS, no esta key
# (ver CLAUDE.md §4.1 y §4.4).
SUPABASE_ANON_KEY=

# Dashboard de Supabase → Project Settings → API → Project API keys → service_role
# SECRETA — bypassea RLS por completo. Solo se usa dentro de Supabase Edge
# Functions. Nunca en el frontend ni en api/config.js.
SUPABASE_SERVICE_ROLE_KEY=

# Proveedor de email transaccional: Resend.
# OJO: esta key NO se usa desde Vercel/frontend — la consume la Supabase Edge
# Function supabase/functions/notificar-solicitud. Se configura con
# `supabase secrets set RESEND_API_KEY=...`, no en Vercel → Environment Variables.
# Se documenta acá solo para que quede registrado qué variables necesita el proyecto.
# Ver CLAUDE.md §13 para el resto de secrets de la Edge Function (EMAIL_FROM, APP_URL).
RESEND_API_KEY=

# PayPhone → panel de comercio → credenciales de API
PAYPHONE_API_KEY=

# api/contacto.js (Vercel Serverless Function) — formulario de contacto y soporte.
# OJO: estas se configuran en Vercel → Project Settings → Environment Variables,
# NO con `supabase secrets set`. Son variables independientes de las que usa la
# Edge Function notificar-solicitud (CLAUDE.md §13), aunque ZOHO_SMTP_USER y
# ZOHO_SMTP_PASSWORD normalmente tengan el mismo valor en ambos lugares.
ZOHO_SMTP_USER=
ZOHO_SMTP_PASSWORD=
EMAIL_FROM=
# Bandeja que recibe los mensajes del formulario de contacto. Si no se
# configura, se usa ZOHO_SMTP_USER como destinatario.
SUPPORT_EMAIL=
